generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  clerkId       String    @unique
  email         String    @unique
  name          String?
  isAdmin       Boolean   @default(false)
  plan          Plan      @default(FREE)
  planExpiresAt DateTime?
  createdAt     DateTime  @default(now())
  cvs           CV[]
}

enum Plan {
  FREE
  PRO
  TEAM
}

model CV {
  id         String   @id @default(cuid())
  userId     String
  shareId    String   @unique @default(cuid())
  isShared   Boolean  @default(true)
  title      String   @default("My CV")
  templateId String   @default("t3")
  data       Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([shareId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  metadata  Json
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model FeatureFlag {
  id          String   @id
  name        String   @unique
  enabled     Boolean  @default(true)
  description String
  updatedAt   DateTime @updatedAt
}

model Announcement {
  id        String   @id @default(cuid())
  message   String
  color     String   @default("info")
  startsAt  DateTime
  endsAt    DateTime
  freeOnly  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Report {
  id         String   @id @default(cuid())
  shareId    String
  reason     String
  reportedBy String?
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([resolved])
}

model PDFLog {
  id         String   @id @default(cuid())
  userId     String
  templateId String
  success    Boolean
  errorMsg   String?
  durationMs Int?
  createdAt  DateTime @default(now())

  @@index([success])
  @@index([createdAt])
}
