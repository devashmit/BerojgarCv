# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# -----------------------------------------------
# ENV FILES — never commit secrets
# -----------------------------------------------
.env
.env.local
.env.development
.env.production
.env.staging
.env*.local
.env.*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma generated client & local migrations
/src/generated/prisma

# -----------------------------------------------
# SENSITIVE KEYS & CERTIFICATES
# -----------------------------------------------
*.pem
*.key
*.p12
*.pfx
*.cert
*.crt
*.csr
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
*.secret

# -----------------------------------------------
# LOGS & TEMP OUTPUT FILES
# -----------------------------------------------
*.log
lint_output.txt
validate_out.txt
npm-debug.log
yarn-debug.log
yarn-error.log

# -----------------------------------------------
# BACKUP / TEMP FILES
# -----------------------------------------------
*.bak
*.tmp
*.orig
*.backup

# -----------------------------------------------
# OS / EDITOR ARTIFACTS
# -----------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json
*.swp
*.swo
*~

# -----------------------------------------------
# UPLOAD TEMP / LOCAL MEDIA
# -----------------------------------------------
/public/uploads/
*.upload.tmp
